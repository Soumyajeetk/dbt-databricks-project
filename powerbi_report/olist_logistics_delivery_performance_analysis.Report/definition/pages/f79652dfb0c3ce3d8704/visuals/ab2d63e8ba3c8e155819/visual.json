  "visual": {
    "visualType": "textbox",
    "objects": {
      "general": [
        {
          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "Overview",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "This page tracks supply chain health and transit velocity. It bridges the gap between processing efficiency and customer retention by monitoring exactly how fast packages move from order validation to the customer's doorstep, highlighting regional logjams.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "On-Time Delivery:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The percentage of fulfilled orders successfully delivered to the customer on or before the estimated arrival date set at checkout. This is the core baseline metric for customer fulfillment satisfaction.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Avg Dispatch Speed:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The mean time taken internally to process, pack, and hand off an approved order to the shipping carrier. This evaluates fulfillment center throughput.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Avg Transit Time:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The mean time a package spends traveling with the logistics provider from the initial hub scan to final delivery. This measures external freight performance.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Cancellation Rate %:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The proportion of active orders that are canceled mid-flight during the fulfillment lifecycle. This monitors delivery-phase friction or transit-related fatigue.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Orders in Pipeline:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The live operational backlog—showing the total number of unfulfilled orders currently sitting in an active, mid-transit, or processing state.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center",
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "The Operational Impact of Delivery SLA Compliance on Order Cancellations:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " A dual-axis trend line mapping shipping performance against order cancellations over time. It visually proves whether historical drops in shipping reliability (SLA % drops) directly trigger an increase in customer cancellations.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Fulfillment Bottlenecks: Dispatch vs. Transit Time:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " A state-by-state horizontal breakdown tracking internal warehousing time (yellow) vs. actual road transit time (grey). This allows managers to pinpoint precisely which states experience severe transit legs (like the massive spike seen in Amazonas/AM) to optimize carrier selection.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              }
            ]
          }
        }
      ]
