  "visual": {
    "visualType": "textbox",
    "objects": {
      "general": [
        {
          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "Overview",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "This page acts as an operational health check on transaction friction and revenue protection. By evaluating order failures against financial losses and customer checkout types, it helps teams identify systemic payment blocks or sudden drop-offs before they scale.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Cancelled Orders :",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The absolute volume of transactions that entered a terminal canceled or unavailable state. Sudden spikes indicate potential system time-outs or inventory sync errors.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Lost Revenue :",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The cumulative Gross Merchandise Value (GMV) forfeited from non-fulfilled orders. This serves as the primary metric for measuring the total cost of operational leakage.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Avg Canceled Freight :",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The mean shipping cost calculated for failed orders. This tracks wasted logistics subsidies or sunk shipping costs incurred prior to cancellation.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Boleto Drop-off Rate % :",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " The percentage of generated Boleto invoices that expired without cash receipt. This highlights checkout abandonment or cash-flow delays unique to voucher payment timelines.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Cancellation Distribution by Payment Method:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " A breakdown tracking failed orders across payment options (Credit Card, Boleto, Voucher, Debit Card). Credit cards typically dominate total volume, but a disproportionately large slice here signals potential bank gateway authentication or fraud-filter triggers.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Revenue Loss & Volatility by Product Category:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " A Pareto-style ranking showing exactly which product classifications suffer the highest financial damage (led by high-value segments like ",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "Cool Stuff",
                    "textStyle": {
                      "fontStyle": "italic",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": " and ",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "Sports Leisure",
                    "textStyle": {
                      "fontStyle": "italic",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "). This targets where quality control, supplier verification, or stricter listing policies are needed most to protect revenue",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              }
            ]
          }
        }
      ]
